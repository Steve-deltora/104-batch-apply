{
  "manifest_version": 3,
  "name": "104 批量應徵助手",
  "version": "1.3.1",
  "description": "在 104 人力銀行搜尋結果頁批量應徵職缺，自動確認送出",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.104.com.tw/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.104.com.tw/jobs/search/*",
        "https://www.104.com.tw/jobs/*",
        "https://www.104.com.tw/company/*",
        "https://pda.104.com.tw/work/mate/list/*"
      ],
      "js":  ["content-search.js"],
      "css": ["content-search.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.104.com.tw/job/*"
      ],
      "js": ["content-apply.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
